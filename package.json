{
  "name": "soli-v2.0",
  "version": "0.0.1",
  "description": "WP-theme for soli",
  "scripts": {
    "test": "phplint '**/*.php' '!node_modules/**' && xo '**/*.js'"
  },
  "repository": "git+https://github.com/IanCStewart/wp-theme-soli.git",
  "keywords": [
    "wp",
    "theme",
    "soli"
  ],
  "author": "Ian Stewart <ian.c.stewart@icloud.com>",
  "contributors": [
    "Joran Out <info@joranout.nl>"
  ],
  "license": "MIT",
  "bugs": "https://github.com/IanCStewart/wp-theme-soli/issues",
  "homepage": "https://github.com/IanCStewart/wp-theme-soli#readme",
  "devDependencies": {
    "phplint": "^1.7.4",
    "xo": "^0.18.2"
  },
  "xo": {
    "env": [
      "browser"
    ],
    "semicolon": true,
    "esnext": false,
    "space": true,
    "rules": {
      "unicorn/no-new-buffer": "off",
      "unicorn/filename-case": "off",
      "unicorn/custom-error-definition": "off",
      "unicorn/no-array-instanceof": "off",
      "unicorn/catch-error-name": "off",
      "unicorn/no-process-exit": "off",
      "unicorn/throw-new-error": "off",
      "unicorn/number-literal-case": "off",
      "unicorn/prefer-starts-ends-with": "off",
      "unicorn/prefer-type-error": "off",
      "unicorn/explicit-length-check": "off",
      "unicorn/no-abusive-eslint-disable": "off"
    }
  }
}
